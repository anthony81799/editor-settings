// Place your key bindings in this file to override the defaultsauto[]
[
	//#region TERMINAL
	{
		"key": "ctrl+shift+a",
		"command": "workbench.action.terminal.focusNext",
		"when": "terminalFocus"
	},
	{
		"key": "ctrl+shift+b",
		"command": "workbench.action.terminal.focusPrevious",
		"when": "terminalFocus"
	},
	{
		"key": "ctrl+shift+j",
		"command": "workbench.action.togglePanel"
	},
	{
		"key": "ctrl+shift+n",
		"command": "workbench.action.terminal.new",
		"when": "terminalFocus"
	},
	{
		"key": "ctrl+shift+w",
		"command": "workbench.action.terminal.kill",
		"when": "terminalFocus"
	},
	{
		"key": "ctrl+shift+t",
		"command": "workbench.action.terminal.focus"
	},
	{
		"key": "ctrl+shift+t",
		"command": "workbench.action.focusActiveEditorGroup",
		"when": "terminalFocus"
	},
	{
		"key": "alt+shift+v",
		"command": "workbench.action.terminal.split",
		"when": "terminalFocus && terminalProcessSupported || terminalFocus && terminalWebExtensionContributedProfile"
	},
	{
		"key": "alt+shift+v",
		"command": "workbench.action.terminal.splitActiveTab",
		"when": "terminalProcessSupported && terminalTabsFocus"
	},
	// {
	// 	"key": "alt+shift+h",
	// 	"command": "workbench.action.terminal.unsplit",
	// 	"when": "(terminalFocus && terminalProcessSupported || terminalFocus && terminalWebExtensionContributedProfile) && terminalSplitTerminal"
	// },
	// {
	// 	"key": "alt+shift+h",
	// 	"command": "workbench.action.terminal.unsplit",
	// 	"when": "terminalProcessSupported && terminalTabsFocus && terminalSplitTerminal"
	// },
	//#endregion
	//#region FILE EXPLORER
	// {
	// "key": "h",
	// "command": "list.collapse",
	// "when": "listFocus && !inputFocus"
	// },
	// {
	// "key": "j",
	// "command": "list.focusDown",
	// "when": "listFocus && !inputFocus"
	// },
	// {
	// "key": "k",
	// "command": "list.focusUp",
	// "when": "listFocus && !inputFocus"
	// },
	// {
	// "key": "l",
	// "command": "list.select",
	// "when": "listFocus && !inputFocus"
	// },
	// {
	// "key": "o",
	// "command": "explorer.openWith",
	// "when": "listFocus && !inputFocus"
	// },
	{
		"key": "f",
		"command": "copyFilePath",
		"when": "listFocus && !inputFocus"
	},
	{
		"key": "s",
		"command": "list.toggleSelection",
		"when": "listFocus && !inputFocus"
	},
	{
		"key": "Shift+f",
		"command": "copyRelativeFilePath",
		"when": "listFocus && !inputFocus"
	},
	{
		"key": "n",
		"command": "explorer.newFile",
		"when": "listFocus && !inputFocus"
	},
	{
		"key": "Shift+n",
		"command": "explorer.newFolder",
		"when": "listFocus && !inputFocus"
	},
	// {
	// "key": "Ctrl+d",
	// "command": "list.focusPageDown",
	// "when": "listFocus && !inputFocus"
	// },
	// {
	// "key": "Ctrl+u",
	// "command": "list.focusPageUp",
	// "when": "listFocus && !inputFocus"
	// },
	{
		"key": "Escape",
		"command": "list.clear",
		"when": "listFocus && listHasSelectionOrFocus && !inputFocus"
	},
	{
		"key": "y",
		"command": "filesExplorer.copy",
		"when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !inputFocus"
	},
	{
		"key": "x",
		"command": "filesExplorer.cut",
		"when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !inputFocus"
	},
	{
		"key": "p",
		"command": "filesExplorer.paste",
		"when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !inputFocus"
	},
	{
		"key": "d",
		"command": "moveFileToTrash",
		"when": "explorerResourceMoveableToTrash && explorerViewletVisible && filesExplorerFocus && !explorerResourceReadonly && !inputFocus"
	},
	{
		"key": "c",
		"command": "renameFile",
		"when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
	},
	{
		"key": "Shift+o",
		"command": "explorer.openAndPassFocus",
		"when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !inputFocus"
	},
	{
		"key": "v",
		"command": "filesExplorer.openFilePreserveFocus",
		"when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !inputFocus"
	},
	//#endregion
	//#region EDITOR
	{
		"key": "alt+shift+v",
		"command": "workbench.action.splitEditor",
		"when": "editorTextFocus"
	},
	{
		"key": "alt+shift+h",
		"command": "workbench.action.splitEditorOrthogonal",
		"when": "editorTextFocus"
	},
	{
		"key": "ctrl+shift+alt+left",
		"command": "workbench.action.focusLeftGroup",
		"when": "editorTextFocus"
	},
	{
		"key": "ctrl+shift+alt+down",
		"command": "workbench.action.focusBelowGroup",
		"when": "editorTextFocus"
	},
	{
		"key": "ctrl+shift+alt+up",
		"command": "workbench.action.focusAboveGroup",
		"when": "editorTextFocus"
	},
	{
		"key": "ctrl+shift+alt+right",
		"command": "workbench.action.focusRightGroup",
		"when": "editorTextFocus"
	},
	{
		"key": "alt+d up",
		"command": "editor.action.marker.prev",
		"when": "editorTextFocus"
	},
	{
		"key": "alt+d down",
		"command": "editor.action.marker.next",
		"when": "editorTextFocus"
	},
	{
		"key": "alt+h",
		"command": "editor.action.showDefinitionPreviewHover",
		"when": "editorTextFocus"
	},
	//#endregion
	//#region EXTRA
	{
		"key": "Ctrl+Alt+5",
		"command": "editor.emmet.action.matchTag"
	},
	{
		"key": "Ctrl+Alt+z",
		"command": "workbench.action.toggleZenMode"
	},
	{
		"key": "Ctrl+Alt+l",
		"command": "editor.action.transformToLowercase"
	},
	{
		"key": "Ctrl+Alt+u",
		"command": "editor.action.transformToUppercase"
	},
	{
		"key": "Ctrl+Shift+l",
		"command": "workbench.action.editor.changeLanguageMode"
	},
	{
		"key": "alt+v",
		"command": "toggleVim"
	},
	{
		"key": "ctrl+alt+r",
		"command": "workbench.action.closeFolder"
	},
	{
		"key": "ctrl+alt+a",
		"command": "workbench.action.addRootFolder"
	},
	{
		"key": "ctrl+shift+alt+t",
		"command": "editor.action.changeTabDisplaySize"
	},
	{
		"key": "Ctrl+Alt+i",
		"command": "editor.action.indentationToTabs"
	},
	{
		"key": "Ctrl+Shift+g i",
		"command": "workbench.view.extension.gitlensInspect"
	},
	// {
	// "key": "alt+a",
	// "command": "editor.emmet.action.incrementNumberByOne"
	// },
	// {
	// "key": "alt+x",
	// "command": "editor.emmet.action.decrementNumberByOne"
	// },
	{
		"key": "ctrl+shift+alt+p",
		"command": "workbench.action.pinEditor",
		"when": "!activeEditorIsPinned"
	},
	{
		"key": "ctrl+shift+alt+p",
		"command": "workbench.action.unpinEditor",
		"when": "activeEditorIsPinned"
	},
	{
		"key": "escape",
		"command": "extension.vim_escape",
		"when": "editorTextFocus && vim.active && !inDebugRepl && !parameterHintsVisible && !suggestWidgetVisible"
	},
	{
		"key": "shift+alt+up",
		"command": "-extension.vim_cmd+alt+up",
		"when": "editorTextFocus && vim.active && !inDebugRepl"
	},
	{
		"key": "shift+alt+down",
		"command": "-extension.vim_cmd+alt+down",
		"when": "editorTextFocus && vim.active && !inDebugRepl"
	},
	{
		"key": "ctrl+b",
		"command": "workbench.action.toggleSidebarVisibility",
		"when": "!editorFocus"
	},
	{
		"key": "ctrl+d",
		"command": "editor.action.addSelectionToNextFindMatch",
		"when": "editorFocus && vim.mode != 'Normal'"
	},
	{
		"key": "ctrl+h",
		"command": "editor.action.startFindReplaceAction",
		"when": "(editorFocus || editorIsOpen) && vim.mode != 'Normal'"
	},
	{
		"key": "ctrl+t",
		"command": "workbench.action.showAllSymbols",
		"when": "!editorFocus || vim.mode != 'Normal'"
	},
	{
		"key": "ctrl+n",
		"command": "workbench.action.files.newUntitledFile",
		"when": "!editorFocus || vim.mode != 'Normal'"
	},
	{
		"key": "ctrl+p",
		"command": "workbench.action.quickOpen",
		"when": "!editorFocus || vim.mode != 'Normal'"
	},
	{
		"key": "ctrl+o",
		"command": "workbench.action.files.openFile",
		"when": "!editorFocus || vim.mode != 'Normal'"
	},
	{
		"key": "ctrl+f",
		"command": "actions.find",
		"when": "(editorFocus || editorIsOpen) && vim.mode != 'Normal'"
	},
	{
		"key": "ctrl+[",
		"command": "-extension.vim_ctrl+[",
		"when": "editorTextFocus && vim.active && vim.use<C-[> && !inDebugRepl"
	},
	{
		"key": "ctrl+]",
		"command": "-extension.vim_ctrl+]",
		"when": "editorTextFocus && vim.active && vim.use<C-]> && !inDebugRepl"
	}
]